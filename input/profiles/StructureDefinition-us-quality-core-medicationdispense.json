        "short": "When product was given out or mailed"
      },
      {
        "id": "MedicationDispense.dosageInstruction",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/quality-core/StructureDefinition/uscdiplusquality",
            "valueBoolean": true
          }
        ],
        "path": "MedicationDispense.dosageInstruction",
        "short": "(USCDI+ Quality) How the medication is to be used by the patient or administered by the caregiver"
      },
      {
        "id": "MedicationDispense.dosageInstruction.text",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/quality-core/StructureDefinition/uscdiplusquality",
            "valueBoolean": true
          }
        ],
        "path": "MedicationDispense.dosageInstruction.text",
        "short": "(USCDI+ Quality) Free text dosage instructions e.g. SIG"
      },
      {
        "id": "MedicationDispense.dosageInstruction.timing",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/quality-core/StructureDefinition/uscdiplusquality",
            "valueBoolean": true
          }
        ],
        "path": "MedicationDispense.dosageInstruction.timing",
        "short": "(USCDI+ Quality) When medication should be administered"
      },
      {
        "id": "MedicationDispense.dosageInstruction.route",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/quality-core/StructureDefinition/uscdiplusquality",
            "valueBoolean": true
          }
        ],
        "path": "MedicationDispense.dosageInstruction.route",
        "short": "(USCDI+ Quality) How drug should enter body"
      },
      {
        "id": "MedicationDispense.dosageInstruction.doseAndRate",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/quality-core/StructureDefinition/uscdiplusquality",
            "valueBoolean": true
          }
        ],
        "path": "MedicationDispense.dosageInstruction.doseAndRate",
        "short": "(USCDI+ Quality) Amount of medication administered"
      },
      {
        "id": "MedicationDispense.dosageInstruction.doseAndRate.dose[x]",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/quality-core/StructureDefinition/uscdiplusquality",
            "valueBoolean": true
          }
        ],
        "path": "MedicationDispense.dosageInstruction.doseAndRate.dose[x]",
        "short": "(USCDI+ Quality) Amount of medication per dose",
        "type": [
          {
            "extension": [
              {
                "url": "http://hl7.org/fhir/StructureDefinition/elementdefinition-type-must-support",
                "valueBoolean": true
              }
            ],
            "code": "Quantity",
            "profile": [
              "http://hl7.org/fhir/StructureDefinition/SimpleQuantity"
            ]
          },
          {
            "code": "Range"
          }
        ]
      }
    ]
  },
  "resourceType": "StructureDefinition"
