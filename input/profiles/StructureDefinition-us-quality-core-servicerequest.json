            "code": "Timing"
          }
        ]
      },
      {
        "id": "ServiceRequest.authoredOn",
        "extension": [
          {
            "url": "http://hl7.org/fhir/us/core/StructureDefinition/uscdi-requirement",
            "valueBoolean": true
          },
          {
            "url": "http://fhir.org/guides/onc/us-quality-core/StructureDefinition/uscdiplusquality",
            "valueBoolean": true
          }
        ],
