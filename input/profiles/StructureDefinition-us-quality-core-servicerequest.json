              "http://hl7.org/fhir/us/quality-core/StructureDefinition/us-quality-core-organization",
              "http://hl7.org/fhir/us/quality-core/StructureDefinition/us-quality-core-patient",
              "http://hl7.org/fhir/us/quality-core/StructureDefinition/us-quality-core-relatedperson",
