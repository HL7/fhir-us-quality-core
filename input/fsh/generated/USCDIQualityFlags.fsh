* name.use ^short = "(USCDI+ Quality) usual | official | temp | nickname | anonymous | old | maiden"
* telecom ^extension[http://hl7.org/fhir/us/quality-core/StructureDefinition/us-quality-core-uscdi-quality-extension].valueBoolean = true
* telecom ^short = "(USCDI+ Quality) A contact detail for the individual"
