* telecom.use ^short = "(USCDI+ Quality) home | work | temp | old | mobile - purpose of this contact point"
* telecom.value ^extension[http://hl7.org/fhir/us/quality-core/StructureDefinition/us-quality-core-uscdi-quality-extension].valueBoolean = true
* telecom.value ^short = "(USCDI+ Quality) The actual contact point details"

